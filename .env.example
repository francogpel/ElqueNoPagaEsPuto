# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  ARCHIVO DE VARIABLES DE ENTORNO                                         ║
# ║  Copiá este archivo como ".env" y completá cada valor                    ║
# ║  NUNCA subas el .env a GitHub — ya está en .gitignore                   ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── URL PÚBLICA ───────────────────────────────────────────────────────────────
# La URL donde está desplegada tu app (sin barra al final)
# En Render la encontrás en el panel, ej: https://cena-app-xxxx.onrender.com
# En desarrollo local podés dejarlo vacío (usa http://localhost:3000)
PUBLIC_URL=https://tu-dominio.onrender.com


# ── MERCADO PAGO — TOKEN PRINCIPAL ───────────────────────────────────────────
# Dónde conseguirlo:
#   1. Entrá a mercadopago.com.ar/developers/panel/app
#   2. Creá una aplicación (o usá una existente)
#   3. En "Credenciales de producción" → copiá el Access Token
#   4. Para PRUEBAS sin plata real → usá "Credenciales de prueba" (empieza con TEST-)
#
# ⚠️  Para que los pagos lleguen a la cuenta del admin, el admin debe conectar
#     su propio MP desde la app (botón "Conectar con Mercado Pago").
#     Este token es el fallback del sistema.
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000


# ── MERCADO PAGO — OAUTH (para que el admin conecte SU cuenta) ───────────────
# Dónde conseguirlos:
#   1. En tu aplicación de MP Developers → sección "Credenciales OAuth"
#   2. Copiá "Client ID" y "Client Secret"
#   3. En "URLs de redirección" agregá: https://tu-dominio.onrender.com/api/mp-oauth/callback
#      (Esta URL debe ser EXACTAMENTE igual a PUBLIC_URL + /api/mp-oauth/callback)
#
# ⚠️  Si no configurás esto, el botón "Conectar con Mercado Pago" no va a funcionar.
MP_CLIENT_ID=0000000000000000
MP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── FIREBASE — CONFIGURACIÓN WEB (valores públicos, van al frontend) ──────────
# Dónde conseguirlos:
#   1. Entrá a console.firebase.google.com
#   2. Abrí tu proyecto → Configuración del proyecto (ícono engranaje)
#   3. En "General" → "Tus apps" → seleccioná tu app web
#   4. Copiá los valores del objeto firebaseConfig
FIREBASE_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
FIREBASE_PROJECT_ID=tu-proyecto


# ── FIREBASE — SERVICE ACCOUNT (privado, solo el backend) ─────────────────────
# Dónde conseguirlo:
#   1. Firebase Console → Configuración del proyecto → Cuentas de servicio
#   2. Hacé clic en "Generar nueva clave privada" → se descarga un JSON
#   3. Convertí ese JSON a base64:
#      • Mac/Linux: base64 -i serviceAccount.json | tr -d '\n'
#      • Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccount.json"))
#   4. Pegá el resultado acá (es una cadena muy larga en una sola línea)
#
# ⚠️  Este valor es secreto. Nunca lo compartas ni lo subas a GitHub.
FIREBASE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6InR1LXByb3llY3RvIiwi...


# ── PUERTO ────────────────────────────────────────────────────────────────────
# Render y Railway inyectan este valor automáticamente.
# En desarrollo local podés cambiar el 3000 por otro puerto si ya lo tenés ocupado.
PORT=3000
